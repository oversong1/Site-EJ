# Laravel 13 + PHP 8.3
APP_NAME="EJ Tecnologia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Credenciais do painel admin
ADMIN_EMAIL=admin@ejtecnologia.com.br
ADMIN_PASSWORD=ej@admin2026

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Banco de dados MySQL (Docker)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ej_tecnologia
DB_USERNAME=ej_user
DB_PASSWORD=ej_password_2026

# ── Cache / Session / Queue
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=480

# ── Sanctum (tokens API)
SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DOMAIN=localhost

